# ============================================================
# StarCoin 配置模板
# 复制此文件为 .env 并按需修改：
#   cp .env.example .env
# ============================================================

# -------- 节点配置 --------
PORT=3000                                          # HTTP/WS 服务端口
SEED_PEERS=                                        # 种子节点列表（逗号分隔，如 "ws://localhost:3000,ws://localhost:3001"）
# NODE_NAME=                                       # 自定义节点名称（可选，默认自动生成）

# -------- P2P 重连配置 --------
P2P_RECONNECT_BASE_DELAY=1000                      # 重连初始延迟（毫秒）
P2P_RECONNECT_MAX_DELAY=30000                      # 重连最大延迟（毫秒）
P2P_RECONNECT_MAX_RETRIES=50                       # 最大重试次数
P2P_RECONNECT_JITTER=0.3                           # 随机抖动系数（0~1）

# -------- P2P 心跳配置 --------
P2P_HEARTBEAT_INTERVAL=15000                       # 心跳发送间隔（毫秒）
P2P_HEARTBEAT_TIMEOUT=6000                         # 心跳超时阈值（毫秒）

# -------- 节点发现配置 --------
P2P_DISCOVERY_INTERVAL=30000                       # 自动发现请求间隔（毫秒）
P2P_DISCOVERY_MAX_PEERS=20                         # 最大对等节点数
P2P_DISCOVERY_MAX_PER_ROUND=3                      # 每轮最大尝试连接数

# -------- 链同步配置 --------
SYNC_TIMEOUT=10000                                 # 同步响应超时（毫秒）
SYNC_INTERVAL=60000                                # 定期自动同步间隔（毫秒）
SYNC_HEALTH_CHECK_INTERVAL=30000                   # 链健康检查间隔（毫秒）
SYNC_STARTUP_CONNECT_DELAY=1500                    # 启动后首次连接延迟（毫秒）

# -------- 挖矿/区块配置 --------
MINING_REWARD=50                                   # 矿工奖励金额
MINING_COINBASE_MATURITY=5                         # 矿工奖励锁定期（区块数）
MINING_MAX_TXS_PER_BLOCK=100                       # 每区块最大打包交易数

# -------- 难度调整配置 --------
DIFFICULTY_INITIAL=5                               # 初始难度
DIFFICULTY_TARGET_TIME=12                          # 目标出块时间（秒）
DIFFICULTY_ADJUST_INTERVAL=6                       # 每 N 个区块调整一次
DIFFICULTY_MIN=3                                   # 最小难度
DIFFICULTY_MAX=12                                  # 最大难度
DIFFICULTY_STEP=0.1                                # 调整步长

# -------- API 限流配置 --------
RATE_LIMIT_GLOBAL_WINDOW_MS=60000                  # 全局限流窗口（毫秒）
RATE_LIMIT_GLOBAL_MAX=60                           # 全局最大请求数 / 窗口（1 req/s）
RATE_LIMIT_WRITE_WINDOW_MS=60000                   # 写操作限流窗口（毫秒）
RATE_LIMIT_WRITE_MAX=10                            # 写操作最大请求数 / 窗口
RATE_LIMIT_SEARCH_WINDOW_MS=60000                  # 搜索限流窗口（毫秒）
RATE_LIMIT_SEARCH_MAX=20                           # 搜索最大请求数 / 窗口